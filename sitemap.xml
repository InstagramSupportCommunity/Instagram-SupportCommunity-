    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            background: #f4f4f4;
            color: #333;
            margin: 0;
            padding: 40px 20px;
        }
        .container {
            max-width: 900px;
            margin: 0 auto;
            background: white;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 5px 25px rgba(0,0,0,0.1);
        }
        h1 {
            text-align: center;
            color: #e1306c;
            margin-bottom: 10px;
        }
        p {
            text-align: center;
            color: #666;
        }
        ul {
            list-style: none;
            padding: 0;
            margin-top: 30px;
        }
        li {
            margin: 12px 0;
            padding: 16px 20px;
            background: #fafafa;
            border: 1px solid #eee;
            border-radius: 8px;
            transition: 0.3s;
        }
        li:hover {
            background: #fff0f5;
            border-color: #e1306c;
        }
        a {
            text-decoration: none;
            color: #e1306c;
            font-size: 1.05em;
            font-weight: 500;
        }
        a:hover {
            text-decoration: underline;
        }
        .lastmod {
            font-size: 0.85em;
            color: #888;
            margin-top: 6px;
