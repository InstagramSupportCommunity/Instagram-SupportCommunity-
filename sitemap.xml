<!DOCTYPE html>
<html lang="en">
<head>
    <title>Follcrease - Sitemap</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f8f9fa;
            color: #333;
            margin: 0;
            padding: 40px 20px;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        }
        h1 {
            text-align: center;
            color: #e1306c;
        }
        ul {
            list-style: none;
            padding: 0;
        }
        li {
            margin: 15px 0;
            padding: 12px 15px;
            background: #f1f1f1;
            border-radius: 8px;
            transition: all 0.3s;
        }
        li:hover {
            background: #ffe6f0;
            transform: translateX(10px);
        }
        a {
            text-decoration: none;
            color: #e1306c;
            font-weight: 500;
            word-break: break-all;
        }
        a:hover {
            text-decoration: underline;
        }
        .lastmod {
            font-size: 0.9em;
            color: #666;
            margin-top: 5px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🌐 Follcrease Sitemap</h1>
        <p style="text-align:center; color:#555;">Last Updated: 29 June 2026</p>
        
        <ul>
            <li>
                <a href="https://instagramsupportcommunity.github.io/Followbots/" target="_blank">
                    Home
                </a>
                <div class="lastmod">Priority: 1.00</div>
            </li>
            <li>
                <a href="https://instagramsupportcommunity.github.io/Followbots/privacy-policy.html" target="_blank">
                    Privacy Policy
                </a>
                <div class="lastmod">Priority: 0.80</div>
            </li>
            <li>
                <a href="https://instagramsupportcommunity.github.io/Followbots/terms-of-service.html" target="_blank">
                    Terms of Service
                </a>
                <div class="lastmod">Priority: 0.80</div>
            </li>
        </ul>
    </div>
</body>
</html>
